{
  "_meta": {
    "template_version": 1,
    "note": "Montants en centimes EUR alignés sur l'UI (9,90 €/mois, pass session 49 €). À charger dans Stripe CLI ou dashboard de test."
  },
  "fixtures": [
    {
      "name": "prod_mensuel",
      "path": "/v1/products",
      "method": "post",
      "params": {
        "name": "Premium Mensuel",
        "description": "Abonnement mensuel — accès premium.",
        "metadata": {
          "price_card_variant": "mensuel",
          "support_level": "email"
        }
      }
    },
    {
      "name": "price_mensuel_month",
      "path": "/v1/prices",
      "method": "post",
      "params": {
        "product": "${prod_mensuel:id}",
        "currency": "eur",
        "billing_scheme": "per_unit",
        "unit_amount": 990,
        "recurring": {
          "interval": "month",
          "interval_count": 1
        }
      }
    },
    {
      "name": "prod_examen",
      "path": "/v1/products",
      "method": "post",
      "params": {
        "name": "Premium Jusqu'à l'examen",
        "description": "Accès premium jusqu'au jour de l'épreuve.",
        "metadata": {
          "price_card_variant": "examen",
          "support_level": "email"
        }
      }
    },
    {
      "name": "price_examen_onetime",
      "path": "/v1/prices",
      "method": "post",
      "params": {
        "product": "${prod_examen:id}",
        "currency": "eur",
        "billing_scheme": "per_unit",
        "unit_amount": 4900
      }
    }
  ]
